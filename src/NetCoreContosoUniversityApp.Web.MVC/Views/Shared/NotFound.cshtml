@{
    ViewData["Title"] = "Not Found";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-1 text-danger">404</h1>
        <h2 class="mb-4">@ViewBag.ErrorTitle</h2>
        <p class="lead mb-4">@ViewBag.ErrorMessage</p>

        @if (ViewBag.OriginalPath != null)
        {
            <p class="text-muted">
                <small>Requested path: @ViewBag.OriginalPath@ViewBag.OriginalQueryString</small>
            </p>
        }

        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
                <i class="bi bi-house-door"></i> Go Home
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Go Back
            </a>
        </div>
    </div>
</div>