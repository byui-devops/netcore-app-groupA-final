@{
    ViewData["Title"] = ViewBag.ErrorTitle ?? "Error";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-1 text-danger">Error</h1>
        <h2 class="mb-4">@ViewBag.ErrorTitle</h2>
        <p class="lead mb-4">@ViewBag.ErrorMessage</p>

        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-door"></i> Go Home
            </a>
        </div>
    </div>
</div>