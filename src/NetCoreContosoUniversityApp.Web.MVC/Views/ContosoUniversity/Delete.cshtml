@using NetCoreContosoUniversityApp.Service.Dtos.ContosoUniversity
@model StudentDto

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-3 border">
                <div class="card-header border-0 bg-danger text-white">
                    <h4 class="mb-0">Delete Student</h4>
                    <p class="text-danger">@ViewData["ErrorMessage"]</p>
                </div>
                <div class="card-body">
                    <h5 class="text-danger mb-4">Are you sure you want to delete this student?</h5>

                    <!-- Image Preview (Default or Existing) -->
                    <div class="mb-3 text-center">
                        <img id="previewImage"
                            src="@(string.IsNullOrEmpty(Model?.ImagePath)
                                ? Url.Content("~/images/defaults/default-students.png")
                                : Url.Content(Model.ImagePath))"
                            alt="Student profile"
                            class="img-thumbnail"
                            style="max-width: 150px;" />
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4 fw-semibold text-secondary">
                            @Html.DisplayNameFor(model => model.LastName)
                        </dt>
                        <dd class="col-sm-8">
                            @Html.DisplayFor(model => model.LastName)
                        </dd>

                        <dt class="col-sm-4 fw-semibold text-secondary">
                            @Html.DisplayNameFor(model => model.FirstMidName)
                        </dt>
                        <dd class="col-sm-8">
                            @Html.DisplayFor(model => model.FirstMidName)
                        </dd>

                        <dt class="col-sm-4 fw-semibold text-secondary">
                            @Html.DisplayNameFor(model => model.EnrollmentDate)
                        </dt>
                        <dd class="col-sm-8">
                            @Html.DisplayFor(model => model.EnrollmentDate)
                        </dd>
                    </dl>

                    <hr />

                    <form asp-controller="ContosoUniversity" asp-action="delete" asp-route-id="@Model.Id" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-controller="ContosoUniversity" asp-action="list" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left-circle"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const img = document.getElementById("previewImage");

            if (img) {
                img.addEventListener("error", function () {
                    this.src = '/images/defaults/default-students.png';
                });
            }
        });
    </script>
}