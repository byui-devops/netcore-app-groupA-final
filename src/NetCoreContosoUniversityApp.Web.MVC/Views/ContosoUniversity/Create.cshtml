@using NetCoreContosoUniversityApp.Service.Dtos.ContosoUniversity
@model StudentDto

@{
    ViewData["Title"] = "Create Student";
}

<div class="container mt-5">
    <div class="card shadow-sm rounded-3">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                <i class="bi bi-person-plus-fill me-2"></i> Create Student
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>

                <!-- Image Preview (Default or Existing) -->
                <div class="mb-3 text-center">
                    <img id="previewImage"
                        src="@(string.IsNullOrEmpty(Model?.ImagePath)
                            ? Url.Content("~/images/defaults/default-students.png")
                            : Url.Content(Model.ImagePath))"
                        alt="Student profile"
                        class="img-thumbnail"
                        style="max-width: 150px;" />
                </div>

                <!-- Upload Image -->
                <div class="mb-3">
                    <label asp-for="Image" class="form-label fw-semibold"></label>
                    <input asp-for="Image"
                           type="file"
                           class="form-control"
                           accept="image/*"
                           onchange="previewFile(event)" />
                    <span asp-validation-for="Image" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LastName" class="form-label fw-semibold"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FirstMidName" class="form-label fw-semibold"></label>
                    <input asp-for="FirstMidName" class="form-control" />
                    <span asp-validation-for="FirstMidName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GovernmentId" class="form-label fw-semibold"></label> (only numbers)
                    <input asp-for="GovernmentId" class="form-control" />
                    <span asp-validation-for="GovernmentId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EnrollmentDate" class="form-label fw-semibold"></label>
                    <input asp-for="EnrollmentDate" class="form-control" type="date" />
                    <span asp-validation-for="EnrollmentDate" class="text-danger"></span>
                </div>

                <hr />

                <div class="d-flex justify-content-end">
                    <a asp-controller="ContosoUniversity" asp-action="list" class="btn btn-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Create
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewFile(event) {
            const input = event.target;
            const preview = document.getElementById('previewImage');

            if (input.files && input.files[0]) {
                preview.src = URL.createObjectURL(input.files[0]);
            }
        }
        
        document.addEventListener("DOMContentLoaded", function () {
            const img = document.getElementById("previewImage");

            if (img) {
                img.addEventListener("error", function () {
                    this.src = '/images/defaults/default-students.png';
                });
            }
        });
    </script>
}